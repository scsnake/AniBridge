{
  "manifest_version": 3,
  "name": "__MSG_appName__",
  "version": "0.9.1",
  "default_locale": "zh_TW",
  "description": "__MSG_appDescription__",
  "permissions": ["storage"],
  "host_permissions": [
    "https://api.bgm.tv/*",
    "https://graphql.anilist.co/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": false
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "__MSG_actionTitle__",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://ani.gamer.com.tw/animeVideo.php*"],
      "js": ["lib/i18n.js", "lib/platforms.js", "lib/ui.js", "content-gamer.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://myanimelist.net/anime/*",
        "https://anilist.co/anime/*"
      ],
      "js": ["lib/i18n.js", "lib/platforms.js", "lib/ui.js", "content-database.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.disneyplus.com/*",
        "https://www.netflix.com/*",
        "https://hamivideo.hinet.net/product/*"
      ],
      "js": ["lib/i18n.js", "lib/platforms.js", "lib/streaming-adapters.js", "lib/local-ai.js", "lib/ui.js", "content-streaming.js"],
      "run_at": "document_idle"
    }
  ]
}
